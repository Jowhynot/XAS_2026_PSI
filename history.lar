xftr(_feffit_dataset.model, rmin=1.000, rmax=5.000, dr=0.100, window='hanning')

# ffts on group _feffit_dataset.data
xftf(_feffit_dataset.data, kmin=2.500, kmax=11.000, dk=1.500, window='Hanning', kweight=2.000)
xftr(_feffit_dataset.data, rmin=1.000, rmax=5.000, dr=0.100, window='hanning')

# generate chi(k), chi(R), and chi(q) for each path
for label, path in _feffit_dataset.paths.items():
     path.calc_chi_from_params(_feffit_result.paramgroup)
     xftf(path, kmin=2.500, kmax=11.000, dk=1.500,
         window='Hanning', kweight=2.000)
     xftr(path, rmin=1.000, rmax=5.000, dr=0.100, window='hanning')
